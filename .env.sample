# DeepWiki Open — Environment Configuration
# Copy to .env and fill in your values: cp .env.sample .env
#
# At least ONE AI provider key is required.

# === Required: AI Provider Keys (choose at least one) ===
GOOGLE_API_KEY=your-google-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# === Optional: Azure OpenAI ===
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_VERSION=

# === Optional: AWS Bedrock ===
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# === Optional: Ollama (fully local, no external API needed) ===
# OLLAMA_HOST=http://host.docker.internal:11434

# === Optional: Embedder Configuration ===
# Options: google, openai, ollama, bedrock
# DEEPWIKI_EMBEDDER_TYPE=google

# === Optional: Auth Mode (enable if exposing on network) ===
# DEEPWIKI_AUTH_MODE=false
# DEEPWIKI_AUTH_CODE=your-secret-code-here

# === Optional: Server Configuration ===
# PORT=8001
# LOG_LEVEL=INFO
# LOG_FILE_PATH=api/logs/application.log
